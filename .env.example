# Car Rental App — Environment Variables Template
# Copy this to .env and fill in your values:
#   cp .env.example .env

# Server
SERVER_PORT=8080

# Database (PostgreSQL)
# Create a local DB named car_rental_db before running
DB_URL=jdbc:postgresql://localhost:5432/car_rental_db
DB_USERNAME=your_postgres_username
DB_PASSWORD=your_postgres_password
DB_DRIVER=org.postgresql.Driver

# JPA / Hibernate
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_DIALECT=org.hibernate.dialect.PostgreSQL10Dialect
JPA_FORMAT_SQL=true
JPA_OPEN_IN_VIEW=false

# File Upload
MULTIPART_MAX_FILE_SIZE=10MB
MULTIPART_MAX_REQUEST_SIZE=30MB

# Session & Security
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=lax
ERROR_INCLUDE_MESSAGE=always